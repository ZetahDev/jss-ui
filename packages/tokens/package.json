{
  "name": "@js-solutions/tokens",
  "version": "0.0.0",
  "private": false,
  "description": "Design tokens package for JS Solutions UI.",
  "license": "MIT",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "build",
    "dist",
    "tokens",
    "tokens.css",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./tokens.css",
    "./tokens.json": "./tokens/index.json",
    "./ios/DesignTokens.swift": "./build/ios/DesignTokens.swift",
    "./android/tokens.xml": "./build/android/tokens.xml",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm run build:tokens && pnpm run build:platforms && tsup --config tsup.config.ts",
    "build:tokens": "style-dictionary build --config style-dictionary.config.json",
    "build:platforms": "node ./scripts/generate-platform-artifacts.mjs",
    "clean:tokens": "style-dictionary clean --config style-dictionary.config.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint not configured yet for @js-solutions/tokens')\"",
    "test": "node -e \"console.log('test not configured yet for @js-solutions/tokens')\""
  },
  "devDependencies": {
    "style-dictionary": "^5.4.0"
  }
}
