{
  "name": "@js-solutions/tokens",
  "version": "0.0.0",
  "private": false,
  "description": "Design tokens package for JS Solutions UI.",
  "license": "MIT",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "tokens",
    "tokens.css",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./tokens.css",
    "./tokens.json": "./tokens/index.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint not configured yet for @js-solutions/tokens')\"",
    "test": "node -e \"console.log('test not configured yet for @js-solutions/tokens')\""
  }
}
