{
  "name": "@zetahdev/icons",
  "version": "0.0.1",
  "private": false,
  "description": "React icon package for JS Solutions UI.",
  "license": "MIT",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint not configured yet for @zetahdev/icons')\"",
    "test": "node -e \"console.log('test not configured yet for @zetahdev/icons')\""
  }
}
