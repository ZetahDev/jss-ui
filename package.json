{
  "name": "jss-ui",
  "private": true,
  "description": "Production-grade monorepo for the JS Solutions design system.",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10.8.0 <11"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "storybook": "turbo run storybook --parallel",
    "clean": "node -e \"require('node:fs').rmSync('.turbo',{ recursive: true, force: true })\""
  },
  "devDependencies": {
    "@types/node": "^22.18.10",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "tsup": "^8.5.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}
